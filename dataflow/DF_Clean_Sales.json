{
	"name": "DF_Clean_Sales",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "sales_dataset_csv_Bronze",
						"type": "DatasetReference"
					},
					"name": "sourceBronzeSales"
				},
				{
					"dataset": {
						"referenceName": "customer_dataset_json_bronze",
						"type": "DatasetReference"
					},
					"name": "sourceBronzecustomer"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_ADLS_sargcs1",
						"type": "LinkedServiceReference"
					},
					"name": "sinkSilverHighValueData"
				},
				{
					"dataset": {
						"referenceName": "standardsales",
						"type": "DatasetReference"
					},
					"name": "sink2"
				},
				{
					"dataset": {
						"referenceName": "Dim_customer_gold",
						"type": "DatasetReference"
					},
					"name": "dimcustomer"
				},
				{
					"dataset": {
						"referenceName": "customer_sales_summary_gold",
						"type": "DatasetReference"
					},
					"name": "customersalessummary"
				}
			],
			"transformations": [
				{
					"name": "SelectingRequiredColumns"
				},
				{
					"name": "FilteringNullQuantities"
				},
				{
					"name": "castingQuantitytoInteger"
				},
				{
					"name": "CalculateTotalAudit"
				},
				{
					"name": "SplitByValue"
				},
				{
					"name": "LookupCustomerDetails"
				},
				{
					"name": "TagForUpsert"
				},
				{
					"name": "AggregateCustomerSales"
				},
				{
					"name": "GenerateCustomerSK"
				}
			],
			"scriptLines": [
				"source(output(",
				"          TransactionID as short,",
				"          CustomerID as string,",
				"          ProductID as string,",
				"          Quantity as string,",
				"          Price as double,",
				"          StoreLocation as string,",
				"          TransactionDate as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceBronzeSales",
				"source(output(",
				"          CustID as string,",
				"          Name as string,",
				"          SignupDate as date,",
				"          Status as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'arrayOfDocuments') ~> sourceBronzecustomer",
				"sourceBronzeSales select(mapColumn(",
				"          TransactionID,",
				"          CustomerID,",
				"          ProductID,",
				"          Quantity,",
				"          Price,",
				"          OrderDate = TransactionDate",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectingRequiredColumns",
				"SelectingRequiredColumns filter(Quantity != \"NULL\") ~> FilteringNullQuantities",
				"FilteringNullQuantities cast(output(",
				"          Quantity as integer '000'",
				"     ),",
				"     errors: true) ~> castingQuantitytoInteger",
				"castingQuantitytoInteger derive(TotalAmount = toInteger(Quantity)*toFloat(Price),",
				"          LoadTimestamp = currentTimestamp()) ~> CalculateTotalAudit",
				"CalculateTotalAudit split(TotalAmount>=100,",
				"     disjoint: false) ~> SplitByValue@(HighValueSales, StandardSales)",
				"SplitByValue@HighValueSales, sourceBronzecustomer lookup(CustomerID == CustID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> LookupCustomerDetails",
				"LookupCustomerDetails alterRow(upsertIf(true())) ~> TagForUpsert",
				"CalculateTotalAudit aggregate(groupBy(CustomerID),",
				"     TotalRevenue = sum(TotalAmount),",
				"          TotalItems = sum(toInteger(Quantity))) ~> AggregateCustomerSales",
				"sourceBronzecustomer keyGenerate(output(CustomerKey as long),",
				"     startAt: 1L,",
				"     stepValue: 1L) ~> GenerateCustomerSK",
				"TagForUpsert sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delta',",
				"     fileSystem: 'datalake',",
				"     folderPath: 'silver',",
				"     mergeSchema: false,",
				"     autoCompact: false,",
				"     optimizedWrite: false,",
				"     vacuum: 0,",
				"     deletable: false,",
				"     insertable: false,",
				"     updateable: false,",
				"     upsertable: true,",
				"     keys:['TransactionID'],",
				"     partitionFileNames:['cleaned_sales.parquet'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sinkSilverHighValueData",
				"SplitByValue@StandardSales sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink2",
				"GenerateCustomerSK sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> dimcustomer",
				"AggregateCustomerSales sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> customersalessummary"
			]
		}
	}
}